{
  "name": "@proofcomputer/switchboard-fastify",
  "version": "0.1.0",
  "description": "Fastify adapter for Switchboard Acurast webserver jobs.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "node --import tsx --test test/**/*.spec.ts",
    "prepare": "npm run build",
    "pack:dry-run": "npm pack --dry-run --json"
  },
  "dependencies": {
    "@proofcomputer/switchboard-sdk": "github:proof-computer/switchboard-sdk#main"
  },
  "peerDependencies": {
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "fastify": "^5.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
