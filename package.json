{
  "name": "@proof-computer/switchboard-fastify",
  "version": "0.2.2",
  "description": "Fastify adapter for Switchboard Acurast webserver jobs.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proof-computer/switchboard-fastify.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "node --import tsx --test test/**/*.spec.ts",
    "prepare": "npm run build",
    "pack:dry-run": "npm pack --dry-run --json"
  },
  "dependencies": {
    "@proof-computer/switchboard-runtime": "0.1.3"
  },
  "peerDependencies": {
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "fastify": "^5.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@proof-computer/switchboard-runtime"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  }
}
